# pgwen environment variables — copy to `.env` and populate.
# .env is gitignored by default; commit `.env.example` as documentation.

# ─── AI providers ────────────────────────────────────────────────────────────
# Only set the key(s) for the providers you use.

# Claude (default — used by `pgwen new`, `pgwen diagnose`, runtime heal)
ANTHROPIC_API_KEY=

# OpenAI — enable via --provider openai or PGWEN_AI_PROVIDER=openai
OPENAI_API_KEY=

# Azure OpenAI — enable via --provider azure-openai
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
# Either AZURE_OPENAI_RESOURCE (short name) or AZURE_OPENAI_BASE_URL (full URL)
AZURE_OPENAI_RESOURCE=
# AZURE_OPENAI_BASE_URL=

# GitHub Copilot — enable via --provider copilot
GITHUB_TOKEN=

# Pin the provider without --provider on every invocation
# PGWEN_AI_PROVIDER=claude

# Offline / CI mode: use the built-in MockAdapter, no outbound network
# PGWEN_AI_PROVIDER=mock
# PGWEN_AI_MOCK_FIXTURES=./fixtures/ai-mock

# ─── Runtime overrides ──────────────────────────────────────────────────────

# Environment name — populates ${env.*} bindings from pgwen/conf/env/<name>.json
# PGWEN_ENV=test

# Browser override — same values as `pgwen --browser`
# PGWEN_BROWSER=chromium

# Parallel execution knob — max concurrent workers
# PGWEN_PARALLEL=4

# Video capture toggle
# PGWEN_VIDEO=false

# Remote Playwright endpoint (Selenium-style grid via CDP)
# PGWEN_REMOTE_URL=

# ─── CI registry (optional) ─────────────────────────────────────────────────

# If your org proxies npm through an internal registry, set on CI so
# `yarn install --frozen-lockfile` routes through it. On personal forks
# without this secret, CI falls back to public npm.
# PGWEN_NPM_REGISTRY=https://nexus.example.com/repository/npm-proxy/
